<html lang="en" xmlns="http://www.w3.org/1999/xhtml">
  <head>
    <meta charset="UTF-8" />
    <meta content="width=device-width, initial-scale=1" name="viewport" />
    <title>Reset Your Password</title>
    <style>
      body {
        margin: 0;
        padding: 0;
        background: #f6f8fa;
        font-family: "Helvetica Neue", Helvetica, Arial, sans-serif;
        color: #222;
      }
      .container {
        max-width: 600px;
        margin: 24px auto;
        background: #fff;
        border-radius: 10px;
        box-shadow: 0 2px 8px rgba(60, 72, 88, 0.08);
        overflow: hidden;
      }
      .header {
        background: #00296b;
        color: #fff;
        padding: 32px 32px 16px 32px;
        text-align: center;
      }
      .header img {
        height: 48px;
        display: block;
        margin: 0 auto 12px;
      }
      .title {
        margin: 0;
        font-size: 22px;
        font-weight: 700;
        letter-spacing: 1px;
      }
      .body {
        padding: 32px;
      }
      .body h2 {
        margin-top: 0;
        font-size: 18px;
        font-weight: 600;
        color: #1956b4;
      }
      .btn {
        display: inline-block;
        margin-top: 24px;
        padding: 12px 32px;
        background: #00296b;
        color: #fff;
        border-radius: 6px;
        text-decoration: none;
        font-weight: 600;
        font-size: 15px;
      }
      .notice {
        margin-top: 24px;
        padding: 12px 16px;
        background: #fff8e1;
        border-left: 4px solid #f59e0b;
        border-radius: 4px;
        font-size: 14px;
        color: #555;
      }
      .footer {
        text-align: center;
        padding: 18px 20px;
        font-size: 13px;
        background: #f3f5f7;
        color: #8a8e9a;
        border-top: 1px solid #eee;
      }
      .footer a {
        color: #1956b4;
        text-decoration: none;
        margin: 0 8px;
      }
      @media only screen and (max-width: 620px) {
        .container,
        .body,
        .header,
        .footer {
          padding-left: 10px !important;
          padding-right: 10px !important;
        }
      }
    </style>
  </head>
  <body>
    <div class="container">
      <div class="header">
        <img src="YOUR_LOGO_URL" alt="Logo" style="display:block;margin:0 auto;" />
        <div class="title">Reset Your Password</div>
      </div>
      <div class="body">
        <h2>Hello {{name}},</h2>
        <p>We received a request to reset the password for your account associated with <strong>{{email}}</strong>.</p>
        <p>Click the button below to set a new password. This link is valid for <strong>15 minutes</strong>.</p>
        <a href="{{resetUrl}}" class="btn">Reset Password</a>
        <div class="notice">
          If you did not request a password reset, you can safely ignore this email. Your password will remain
          unchanged.
        </div>
      </div>
      <div class="footer">
        &copy;
        {{year}}
        All rights reserved.
      </div>
    </div>
  </body>
</html>